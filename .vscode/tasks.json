{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "npm: compile"
    },
    {
      "label": "vsce: package",
      "type": "shell",
      "command": "npx --yes @vscode/vsce package --out ./release/",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "publish",
      "type": "npm",
      "script": "publish",
      "problemMatcher": ["$tsc"],
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "build and install",
      "type": "shell",
      "command": "npm run build-and-install",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      }
    }
  ]
}
